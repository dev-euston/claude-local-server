{
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(git:*)",
      "Skill(update-config)",
      "Bash(awk 'NR>=140,NR<=175')",
      "Bash(awk 'NR>=745,NR<=790')",
      "Bash(awk 'NR>=104,NR==145')",
      "Bash(awk 'NR>=155,NR==170')"
    ],
    "deny": [
      "Bash(git push:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/elee/Projects/claude-local-server && npm run build && npm run lint && npm run test:coverage",
            "timeout": 120,
            "statusMessage": "Running lint and tests..."
          }
        ]
      }
    ]
  }
}
